
@{
    ViewBag.Title = "Marca";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Mantenimientio</a></li>
    <li class="breadcrumb-item active">Marca</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-users me-1"></i> Lista Marcas
    </div>

    <div class="card-body">
        <div class="row">
            <div class="col-12">
                <button class="btn btn-outline-success" onclick="abrirModal(null)"><i class="fas fa-plus-circle"></i> Crear nuevo</button>
            </div>
        </div>

        <hr />

        <table id="tabla" class="display cell-border" style="width: 100%">
            <thead>
                <tr>
                    <th>Descripcion</th>
                    <th>Activo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>

    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="FormModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="staticBackdropLabel">Marca</h5>
                <button type="button" class="btn-close bg-light" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <input type="hidden" value="0" id="txtId" />

                <div class="row  g-1">
                    <div class="col-sm-6">
                        <label for="txtDescripcion" class="form-label">Descripcion</label>
                        <input type="text" class="form-control" id="txtDescripcion" placeholder="Sabritas, Pato" autocomplete="off">
                    </div>
                    <div class="col-sm-6">
                        <label for="cboActivo" class="form-label">Activo</label>
                        <select id="cboActivo" class="form-select" required>
                            <option value="1">SI</option>
                            <option value="0">NO</option>
                        </select>
                    </div>
                </div>
                @*MENSAJE DE ALERTA*@
                <div class="row mt-3">
                    <div class="col-12">
                        <div id="mensajeError" class="alert alert-danger" role="alert">
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="Guardar()">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section scripts
{
    <script>

        var _dataTable;
        var _filaSeleccionada;


        _dataTable = $('#tabla').
            DataTable({
                responsive: true,
                // Aquí puedes meter más cosas, como el idioma
                ordering: false,
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                },
                "ajax": {
                    url: '@Url.Action("ListarMarca", "Mantenedor")',
                    type: "GET",
                    dataType: "json",
                },
                "columns": [
                    { "data": "Descripcion" },
                    {
                        "data": "Activo", "render": function(valor)
                        {
                            if (valor) {
                                // Usamos 'bg-success' para el verde y 'rounded-pill' si lo quieres ovalado
                                return '<div><span class="badge rounded-pill bg-success">SI</span></div>';
                            } else {
                                // Usamos 'bg-danger' o 'bg-warning' según prefieras el color
                                return '<div><span class="badge bg-danger">NO</span></div>';
                            }
                        }
                    },
                    {
                        "defaultContent": '<button class="btn btn-outline-primary btn-sm btn-editar"><i class="fas fa-pen"></i></button>' +
                                          '<button class="btn btn-outline-danger btn-sm ms-2 btn-eliminar"><i class="fas fa-trash"></i></button>',
                        "orderable": false,  // ¿Se puede ordenar por esta columna? (False para botones)
                        "searchable": false, // ¿El buscador de arriba filtra esta columna?
                        "width": "65px",     // Ancho fijo de la columna
                    }
                ]
            });

        function abrirModal(json) {

            $("#txtId").val(0);
            $("#txtDescripcion").val("");
            $("#cboActivo").val(1);
            $("#mensajeError").hide();

            if (json != null) {
                $("#txtId").val(json.IdMarca);
                $("#txtDescripcion").val(json.Descripcion);
                $("#cboActivo").val(json.Activo == true ? 1 : 0);

            }

            $("#FormModal").modal("show");
        }

        $("#tabla tbody").on("click", '.btn-editar', function () {

            _filaSeleccionada = $(this).closest("tr");
            var data = _dataTable.row(_filaSeleccionada).data();
            //console.log(data);
            abrirModal(data);
        })

        $("#tabla tbody").on("click", '.btn-eliminar', function () {

            var categoriaSeleccionada = $(this).closest("tr");
            var data = _dataTable.row(categoriaSeleccionada).data();
            swal({
                title: "Esta Seguro?",
                text: "¿Desea eliminar la marca?",
                type: "warning",
                showCancelButton: true,
                confirmButtonClass: "btn-primary",
                confirmButtonText: "Si, Borrar!",
                cancelButtonText: "No, Cancelar",
                closeOnConfirm: false,
                closeOnCancel: false
            },
                function (isConfirm) {
                    if (isConfirm) {
                    jQuery.ajax({
                        url: '@Url.Action("EliminarMarca", "Mantenedor")',
                        type: "POST",
                        data: JSON.stringify({ IdMarca: data.IdMarca }),
                        dataType: "json",
                        contentType: "application/json; charset=utf-8",
                        success: function (data) {
                            debugger;
                            if (data.resultado) {
                                _dataTable.row(categoriaSeleccionada).remove().draw();
                                swal("Eliminado!", "La Marca ha sido eliminada!.", "success");
                            } else {
                                swal("No se pudo eliminar", data.mensaje,"error")
                            }
                        },
                        error: function (xhr, status, error) {
                            // ERROR TÉCNICO (Internet, 404, 500)
                            swal("Error de Red", "No se pudo conectar con el servidor. Intente más tarde.", "error");
                            console.log("Detalle técnico: " + error);
                        }
                    });
                    } else {
                        swal("Cancelado", "No se elimino la marca :)", "info");
                    }
                }
            );
            //console.log(data);
        })

        function Guardar() {
            var Marca = {
                IdMarca: $("#txtId").val(),
                Descripcion: $("#txtDescripcion").val(),
                Activo: $("#cboActivo").val() == 1 ? true : false,
            }

            jQuery.ajax({
                url: '@Url.Action("GuardarMarca", "Mantenedor")',
                type: "POST",
                data: JSON.stringify({ objeto: Marca }),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (data) {
                    // Aquí es donde sucede la magia cuando el servidor responde
                    //debugger;
                    $(".modal-body").LoadingOverlay("hide");
                    //CATEGORIA NUEVA
                    if (Marca.IdMarca == 0) {

                        if (data.resultado != 0) {
                            Marca.IdMarca = data.resultado;
                            _dataTable.row.add(Marca).draw(false);
                            $("#FormModal").modal("hide");
                        } else {
                            $("#mensajeError").text(data.mensaje);
                            $("#mensajeError").show();
                        }

                    }
                    //EDITAR CATEGORIA
                    else {

                        if (data.resultado) {
                            _dataTable.row(_filaSeleccionada).data(Marca).draw(false);
                            _filaSeleccionada = null;
                            $("#FormModal").modal("hide");
                        } else {
                            $("#mensajeError").text(data.mensaje);
                            $("#mensajeError").show();
                        }
                    }
                },
                error: function (error) {
                    $(".modal-body").LoadingOverlay("show");
                    $("#mensajeError").text("Error Ajax");
                    $("#mensajeError").show();
                },
                beforeSend: function(){
                    $(".modal-body").LoadingOverlay("show", {
                        imageResizeFactor: 2,
                        text: "Cargando...",
                        size: 14
                    })
                }
            });
        }
    </script>
}
